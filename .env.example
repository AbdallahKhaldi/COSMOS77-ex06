# Copy to .env and fill in real values. NEVER commit .env (CLAUDE.md rule 9).

# Google Gemini free-tier API key (orchestrator only) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# FastMCP StaticTokenVerifier tokens — one per server + the orchestrator's bearer.
COP_MCP_TOKEN=
THIEF_MCP_TOKEN=
ORCHESTRATOR_TOKEN=

# Note: Gmail OAuth uses credentials.json (downloaded) -> token.json (minted on first
# consent). Both are FILES, gitignored — never committed.
