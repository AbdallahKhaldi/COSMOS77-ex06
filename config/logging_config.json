{
  "version": 1,
  "schema_version": "1.00",
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(asctime)s | %(levelname)-7s | %(name)s | %(message)s",
      "datefmt": "%Y-%m-%dT%H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "standard",
      "stream": "ext://sys.stdout"
    },
    "rotating_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "DEBUG",
      "formatter": "standard",
      "filename": "logs/cosmos77_ex06.log",
      "maxBytes": 1048576,
      "backupCount": 5,
      "encoding": "utf-8"
    }
  },
  "loggers": {
    "cosmos77_ex06": {
      "level": "DEBUG",
      "handlers": ["console", "rotating_file"],
      "propagate": false
    }
  },
  "root": {
    "level": "WARNING",
    "handlers": ["console"]
  }
}
